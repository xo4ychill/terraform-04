#############################################################
# Terraform CLI Configuration - STABLE VERSION
# Safe for local + CI/CD usage
#############################################################

#############################################################
# Plugin cache (ускоряет повторные terraform init)
#############################################################

plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

#############################################################
# Disable telemetry / checks (recommended in CI/CD)
#############################################################

disable_checkpoint = true
disable_checkpoint_signature = true

#############################################################
# Provider installation rules
#############################################################

provider_installation {

  ###########################################################
  # 1. Yandex Cloud official mirror (primary source)
  # Highest priority for Yandex Cloud providers
  ###########################################################

  network_mirror {
    url     = "https://terraform-mirror.yandexcloud.net/"
    include = ["yandex-cloud/*"]  # только провайдеры Yandex Cloud
  }

  ###########################################################
  # 2. Community Terraform mirror (library.tf)
  # Secondary mirror for all other providers
  ###########################################################

  network_mirror {
    url     = "https://library.tf/"
    include = ["*/*"]  # все провайдеры, кроме тех, что уже покрыты выше
  }

  ###########################################################
  # 3. Local filesystem mirror (fallback)
  # Используется, если провайдер уже был скачан ранее
  ###########################################################

  filesystem_mirror {
    path    = "$HOME/.terraform.d/providers"
    include = ["*/*"]  # все провайдеры из локального кэша
  }

  ###########################################################
  # 4. Запрет прямого доступа к registry.terraform.io
  # Все запросы к registry.terraform.io блокируются
  ###########################################################

  direct {
    exclude = ["registry.terraform.io/*/*"]  # запрет на прямой доступ ко всем провайдерам из реестра
  }
}

#############################################################
# Logging (optional)
#############################################################

log_level = "WARN"
