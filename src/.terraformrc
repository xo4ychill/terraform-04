#############################################################
# Terraform CLI Configuration - STABLE VERSION
# Safe for local + CI/CD usage
#############################################################

#############################################################
# Plugin cache (ускоряет повторные terraform init)
#############################################################

plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

#############################################################
# Disable telemetry / checks (recommended in CI/CD)
#############################################################

disable_checkpoint = true
disable_checkpoint_signature = true

#############################################################
# Provider installation rules
#############################################################

provider_installation {

  ###########################################################
  # 1. Yandex Cloud official mirror (primary source)
  ###########################################################

  network_mirror {
    url     = "https://terraform-mirror.yandexcloud.net/"
    include = ["yandex-cloud/*"]  # только провайдеры Yandex Cloud
  }

  ###########################################################
  # 2. Official Terraform Registry (fallback)
  ###########################################################

  direct {
    exclude = ["yandex-cloud/*"]  # все запросы к Yandex Cloud — через зеркало
  }
}

#############################################################
# Logging (optional)
#############################################################

log_level = "WARN"
